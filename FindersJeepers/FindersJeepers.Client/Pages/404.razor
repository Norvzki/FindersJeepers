@page "/404"

<MudContainer MaxWidth="MaxWidth.Small" Class="d-flex flex-column align-items-center justify-center min-vh-100 text-center mt-16">
    <MudIcon Icon="@Icons.Material.Filled.Map" Color="Color.Error" Size="Size.Large" Style="font-size: 5rem;" />
    
    <MudText Typo="Typo.h4" Class="mt-4">Resource Not Found</MudText>
    <MudText Typo="Typo.body1" Class="mud-text-secondary mt-2">
        The driver, vehicle, or resource you are looking for does not exist or has been removed from our system.
    </MudText>
    
    <MudButton Variant="Variant.Filled"
               Color="Color.Primary"
               Href="/"
               Class="mt-6"
               StartIcon="@Icons.Material.Filled.Home">
        Back to Dashboard
    </MudButton>
</MudContainer>