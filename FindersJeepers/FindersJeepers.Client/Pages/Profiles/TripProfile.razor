@page "/trips/{Id:int}"
@using MudBlazor
@inject HttpClient Http
@inject ISnackbar Snackbar

<style>
    .passenger-grid {
        display: grid;
        grid-template-columns: repeat(8, 1fr);
        gap: 5px;
        padding: 12px;
        border-radius: 12px;
        background: rgba(128, 128, 128, 0.06);
        user-select: none;
        cursor: pointer;
    }

    .p-icon {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 38px;
        height: 38px;
        border-radius: 8px;
        transition: transform 0.08s ease, background 0.1s ease, color 0.1s ease;
        color: var(--mud-palette-text-disabled);
        position: relative;
    }

    .p-icon:hover {
        transform: scale(1.12);
    }

    .p-icon.selected {
        color: #f59e0b;
        background: rgba(245, 158, 11, 0.14);
        animation: pax-glow 2s ease-in-out infinite alternate;
    }

    .p-icon.preview:not(.selected) {
        color: #fbbf24;
        background: rgba(245, 158, 11, 0.07);
    }

    .p-icon.overload {
        color: #ef4444;
        background: rgba(239, 68, 68, 0.14);
        animation: pax-glow-red 2s ease-in-out infinite alternate;
    }

    @@keyframes pax-glow {
        from { box-shadow: 0 0 0px rgba(245, 158, 11, 0.0); }
        to   { box-shadow: 0 0 8px rgba(245, 158, 11, 0.55); }
    }

    @@keyframes pax-glow-red {
        from { box-shadow: 0 0 0px rgba(239, 68, 68, 0.0); }
        to   { box-shadow: 0 0 8px rgba(239, 68, 68, 0.55); }
    }

    .pax-count-display {
        font-size: 2rem;
        font-weight: 700;
        line-height: 1;
        letter-spacing: -1px;
    }

    .pax-count-overload {
        color: #ef4444;
    }

    .pax-count-warn {
        color: #f59e0b;
    }

    .pax-count-ok {
        color: var(--mud-palette-success);
    }

    .custom-toggle-btn {
        border: 1.5px dashed var(--mud-palette-divider) !important;
        border-radius: 8px !important;
        padding: 6px 14px !important;
        font-size: 0.78rem !important;
        color: var(--mud-palette-text-secondary) !important;
        background: transparent !important;
        cursor: pointer;
        transition: border-color 0.15s, color 0.15s;
    }

    .custom-toggle-btn:hover {
        border-color: var(--mud-palette-primary) !important;
        color: var(--mud-palette-primary) !important;
    }

    .custom-toggle-btn.active {
        border-color: var(--mud-palette-error) !important;
        color: var(--mud-palette-error) !important;
    }
</style>

@if (_trip is null)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    <MudBreadcrumbs Items="_breadcrumbs" Class="mb-4 px-0" />

    <MudGrid Spacing="4">

        @* ── Left column: trip summary card ── *@
        <MudItem xs="12" md="4">
            <MudCard Elevation="2" Style="border-radius:14px;">
                <MudCardContent Class="d-flex flex-column align-items-center text-center pa-6">
                    <MudAvatar Color="@GetStatusColor(_trip.Status)" Style="width:80px;height:80px;" Class="mb-3" Variant="Variant.Filled">
                        <MudIcon Icon="@GetStatusIcon(_trip.Status)" Style="font-size:2.2rem;" />
                    </MudAvatar>

                    <MudText Typo="Typo.h5" Class="fw-bold">Trip #@_trip.Id</MudText>
                    <MudChip T="string" Color="@GetStatusColor(_trip.Status)" Variant="Variant.Filled" Size="Size.Small" Class="mb-4">
                        @_trip.Status
                    </MudChip>

                    <MudDivider Class="w-100 mb-4" />

                    <MudStack Spacing="2" Class="w-100 text-start">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudIcon Icon="@Icons.Material.Filled.DirectionsBus" Size="Size.Small" Class="mud-text-secondary" />
                            <MudText Typo="Typo.body2">
                                <MudLink Href="@($"/jeepneys/{_trip.JeepneyId}")">@_trip.PlateNumber</MudLink>
                            </MudText>
                        </MudStack>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudIcon Icon="@Icons.Material.Filled.Route" Size="Size.Small" Class="mud-text-secondary" />
                            <MudText Typo="Typo.body2">
                                <MudLink Href="@($"/routes/{_trip.RouteId}")">@_trip.RouteCode</MudLink>
                            </MudText>
                        </MudStack>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudIcon Icon="@Icons.Material.Filled.FlightTakeoff" Size="Size.Small" Class="mud-text-secondary" />
                            <MudText Typo="Typo.body2">@(_trip.DepartureTime?.ToString("MMM dd, hh:mm tt") ?? "Not yet departed")</MudText>
                        </MudStack>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudIcon Icon="@Icons.Material.Filled.FlightLand" Size="Size.Small" Class="mud-text-secondary" />
                            <MudText Typo="Typo.body2">@(_trip.ArrivalTime?.ToString("MMM dd, hh:mm tt") ?? "Not yet arrived")</MudText>
                        </MudStack>
                    </MudStack>

                    <MudDivider Class="w-100 my-4" />

                    @* Stats row *@
                    <MudStack Row="true" Justify="Justify.SpaceEvenly" Class="w-100">
                        <MudStack Spacing="0" AlignItems="AlignItems.Center">
                            <MudText Typo="Typo.h6" Class="fw-bold">@_trip.Logs.Count</MudText>
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">Log Events</MudText>
                        </MudStack>
                        <MudDivider Vertical="true" FlexItem="true" />
                        <MudStack Spacing="0" AlignItems="AlignItems.Center">
                            <MudText Typo="Typo.h6" Class="fw-bold">@_trip.Logs.Select(l => l.PassengerCount).DefaultIfEmpty(0).Max()</MudText>
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">Peak Load</MudText>
                        </MudStack>
                        <MudDivider Vertical="true" FlexItem="true" />
                        <MudStack Spacing="0" AlignItems="AlignItems.Center">
                            <MudText Typo="Typo.h6" Class="fw-bold">@TripDuration</MudText>
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">Duration</MudText>
                        </MudStack>
                    </MudStack>

                    @* Actions *@
                    @if (_trip.Status == "Waiting" || _trip.Status == "OnGoing")
                    {
                        <MudDivider Class="w-100 my-4" />
                        <MudStack Spacing="2" Class="w-100">
                            @if (_trip.Status == "Waiting")
                            {
                                <MudButton Variant="Variant.Filled" Color="Color.Success" FullWidth="true"
                                           StartIcon="@Icons.Material.Filled.PlayArrow" OnClick="StartTrip">
                                    Start Trip
                                </MudButton>
                            }
                            @if (_trip.Status == "OnGoing")
                            {
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                                           StartIcon="@Icons.Material.Filled.ListAlt" OnClick="OpenLogDialog">
                                    Log Stop Event
                                </MudButton>
                                <MudButton Variant="Variant.Outlined" Color="Color.Default" FullWidth="true"
                                           StartIcon="@Icons.Material.Filled.CheckCircle" OnClick="CompleteTrip">
                                    Complete Trip
                                </MudButton>
                            }
                        </MudStack>
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>

        @* ── Right column: log timeline + passenger chart ── *@
        <MudItem xs="12" md="8">
            <MudStack Spacing="4">

                @* Passenger Count Over Time *@
                @if (_trip.Logs.Any())
                {
                    <MudCard Elevation="2" Style="border-radius:14px;">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.h6" Class="fw-bold">Passenger Count Over Time</MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudDivider />
                        <MudCardContent>
                            <MudStack Spacing="1">
                                @foreach (var log in _trip.Logs.OrderBy(l => l.Timestamp))
                                {
                                    double pct = _trip.Capacity > 0 ? (double)log.PassengerCount / _trip.Capacity * 100 : 0;
                                    Color barColor = pct >= 100 ? Color.Error : pct >= 80 ? Color.Warning : Color.Success;

                                    <MudStack Spacing="0">
                                        <MudStack Row="true" Justify="Justify.SpaceBetween">
                                            <MudText Typo="Typo.caption">@log.StopName (@log.EventType)</MudText>
                                            <MudText Typo="Typo.caption">@log.PassengerCount / @_trip.Capacity</MudText>
                                        </MudStack>
                                        <MudProgressLinear Value="@pct" Color="@barColor" Rounded="true" Size="Size.Medium" />
                                    </MudStack>
                                }
                            </MudStack>
                        </MudCardContent>
                    </MudCard>
                }

                @* Stop Log Timeline *@
                <MudCard Elevation="2" Style="border-radius:14px;">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6" Class="fw-bold">Stop Log Timeline</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudDivider />
                    <MudCardContent>
                        @if (!_trip.Logs.Any())
                        {
                            <MudAlert Severity="Severity.Info" Dense="true">No stop events logged yet.</MudAlert>
                        }
                        else
                        {
                            <MudTimeline TimelinePosition="TimelinePosition.Start">
                                @foreach (var log in _trip.Logs.OrderBy(l => l.Timestamp))
                                {
                                    <MudTimelineItem Color="@(log.EventType == "Arrival" ? Color.Info : Color.Success)"
                                                     Size="Size.Small" Variant="Variant.Filled">
                                        <ItemContent>
                                            <MudStack Spacing="0">
                                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                                    <MudText Typo="Typo.body1" Class="fw-bold">@log.StopName</MudText>
                                                    <MudChip T="string" Size="Size.Small"
                                                             Color="@(log.EventType == "Arrival" ? Color.Info : Color.Success)"
                                                             Variant="Variant.Outlined">
                                                        @log.EventType
                                                    </MudChip>
                                                </MudStack>
                                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3" Class="mt-1">
                                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                                        <MudIcon Icon="@Icons.Material.Filled.People" Size="Size.Small" Class="mud-text-secondary" />
                                                        <MudText Typo="Typo.body2">@log.PassengerCount passengers</MudText>
                                                    </MudStack>
                                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                                        <MudIcon Icon="@Icons.Material.Filled.AccessTime" Size="Size.Small" Class="mud-text-secondary" />
                                                        <MudText Typo="Typo.caption">@log.Timestamp.ToString("hh:mm:ss tt")</MudText>
                                                    </MudStack>
                                                </MudStack>
                                            </MudStack>
                                        </ItemContent>
                                    </MudTimelineItem>
                                }
                            </MudTimeline>
                        }
                    </MudCardContent>
                </MudCard>

            </MudStack>
        </MudItem>
    </MudGrid>
}

@* ── Log Stop Event Dialog ── *@
<MudDialog Visible="_logDialogVisible" Options="_dialogOptions">
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.ListAlt" Size="Size.Small" />
            <MudText Typo="Typo.h6">Log Stop Event</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3">

            <MudDivider />

            @* ── Passenger count header ── *@
            <MudStack Row="true" AlignItems="AlignItems.Baseline" Justify="Justify.SpaceBetween">
                <MudStack Row="true" AlignItems="AlignItems.Baseline" Spacing="1">
                    <span class="pax-count-display @PaxCountClass">@_logForm.PassengerCount</span>
                    <MudText Typo="Typo.body1" Class="mud-text-secondary">/ @(_trip?.Capacity ?? 0) passengers</MudText>
                </MudStack>

                @if (_logForm.PassengerCount == 0)
                {
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">Tap a seat to select</MudText>
                }
                else if (_logForm.PassengerCount > (_trip?.Capacity ?? 0))
                {
                    <MudChip T="string" Color="Color.Error" Size="Size.Small" Variant="Variant.Filled">
                        +@(_logForm.PassengerCount - (_trip?.Capacity ?? 0)) over capacity
                    </MudChip>
                }
                else
                {
                    var pct = (int)((double)_logForm.PassengerCount / (_trip?.Capacity ?? 1) * 100);
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">@pct% full</MudText>
                }
            </MudStack>

            @* ── Passenger icon grid ── *@
            <div class="passenger-grid"
                 @onmousedown="() => _isDragging = true"
                 @onmouseup="() => _isDragging = false"
                 @onmouseleave="() => { _hoverCount = 0; _isDragging = false; }">
                @for (int i = 1; i <= (_trip?.Capacity ?? 0); i++)
                {
                    int idx = i;
                    bool isSelected = idx <= _logForm.PassengerCount;
                    bool isPreview  = !isSelected && idx <= _hoverCount;

                    <div class="p-icon @(isSelected ? "selected" : "") @(isPreview ? "preview" : "")"
                         @onmouseenter="() => OnIconHover(idx)"
                         @onclick="() => SetPassengerCount(idx)">
                        <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" />
                    </div>
                }
            </div>

            @* ── Overload custom input toggle ── *@
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <button class="custom-toggle-btn @(_showCustomInput ? "active" : "")"
                        type="button"
                        @onclick="ToggleCustomInput">
                    @if (_showCustomInput)
                    {
                        <MudIcon Icon="@Icons.Material.Filled.ExpandLess" Size="Size.Small" Style="vertical-align:middle; margin-right:4px;" />
                        <span>Hide custom count</span>
                    }
                    else
                    {
                        <MudIcon Icon="@Icons.Material.Filled.Warning" Size="Size.Small" Style="vertical-align:middle; margin-right:4px;" />
                        <span>Overloading? Enter custom count</span>
                    }
                </button>
            </MudStack>

            @* ── Custom overload input ── *@
            @if (_showCustomInput)
            {
                <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-0">
                    This will exceed the vehicle's listed capacity of @(_trip?.Capacity ?? 0).
                </MudAlert>
                <MudNumericField @bind-Value="_logForm.PassengerCount"
                                 Label="Custom Passenger Count"
                                 Variant="Variant.Outlined"
                                 Min="0"
                                 Adornment="Adornment.Start"
                                 AdornmentIcon="@Icons.Material.Filled.People"
                                 AdornmentColor="Color.Error"
                                 Required="true" />
            }

        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => _logDialogVisible = false">Cancel</MudButton>
        <MudButton Variant="Variant.Filled"
                   Color="@(_logForm.PassengerCount > (_trip?.Capacity ?? 0) ? Color.Error : Color.Primary)"
                   OnClick="SaveLog">
            @if (_logForm.PassengerCount > (_trip?.Capacity ?? 0))
            {
                <MudIcon Icon="@Icons.Material.Filled.Warning" Size="Size.Small" Class="mr-1" />
                <span>Log (Overloaded)</span>
            }
            else
            {
                <span>Log Event</span>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public int Id { get; set; }

    private TripDetailDto? _trip;
    private List<BreadcrumbItem> _breadcrumbs = new();
    private bool _logDialogVisible = false;
    private LogForm _logForm = new();
    private List<StopOption> _availableStops = new();

    // Passenger selector state
    private int  _hoverCount       = 0;
    private bool _isDragging        = false;
    private bool _showCustomInput   = false;

    private DialogOptions _dialogOptions = new()
    {
        MaxWidth = MaxWidth.Small,
        FullWidth = true,
        CloseOnEscapeKey = true
    };

    // ── Helpers ──────────────────────────────────────────────────────

    private string PaxCountClass => _logForm.PassengerCount > (_trip?.Capacity ?? 0)
        ? "pax-count-overload"
        : _logForm.PassengerCount >= (_trip?.Capacity ?? 0) * 0.8
            ? "pax-count-warn"
            : "pax-count-ok";

    private string TripDuration
    {
        get
        {
            if (_trip?.DepartureTime is null) return "—";
            var end = _trip.ArrivalTime ?? DateTime.Now;
            var dur = end - _trip.DepartureTime.Value;
            return $"{(int)dur.TotalHours}h {dur.Minutes}m";
        }
    }

    // ── Passenger selector logic ──────────────────────────────────────

    private void OnIconHover(int idx)
    {
        _hoverCount = idx;
        if (_isDragging)
            _logForm.PassengerCount = idx;
    }

    private void SetPassengerCount(int count)
    {
        // Clicking the same last icon toggles it off (deselect all)
        _logForm.PassengerCount = _logForm.PassengerCount == count ? 0 : count;
    }

    private void ToggleCustomInput()
    {
        _showCustomInput = !_showCustomInput;
    }

    // ── Data loading ──────────────────────────────────────────────────

    private async Task LoadData()
    {
        _trip = await Http.GetFromJsonAsync<TripDetailDto>($"/api/v1/trips/{Id}");
    }

    protected override async Task OnInitializedAsync()
    {
        await Task.Delay(300);
        await LoadData();
        _availableStops = new List<StopOption>
        {
            new() { Id = 1, Name = "Ayala Center Cebu" },
            new() { Id = 2, Name = "IT Park" },
            new() { Id = 3, Name = "Colon Street" },
            new() { Id = 4, Name = "Carbon Market" },
        };
        _breadcrumbs = new List<BreadcrumbItem>
        {
            new("Trips", href: "/trips"),
            new($"Trip #{_trip?.Id}", href: null, disabled: true)
        };
    }

    // ── Status helpers ────────────────────────────────────────────────

    private Color GetStatusColor(string status) => status switch
    {
        "OnGoing"   => Color.Success,
        "Waiting"   => Color.Warning,
        "Completed" => Color.Default,
        _           => Color.Default
    };

    private string GetStatusIcon(string status) => status switch
    {
        "OnGoing"   => Icons.Material.Filled.DirectionsBus,
        "Waiting"   => Icons.Material.Filled.HourglassTop,
        "Completed" => Icons.Material.Filled.CheckCircle,
        _           => Icons.Material.Filled.Circle
    };

    // ── Trip actions ──────────────────────────────────────────────────

    private async Task StartTrip()
    {
        var response = await Http.PutAsJsonAsync($"/api/v1/trips/{Id}/start", new { });
        if (response.IsSuccessStatusCode)
        {
            Snackbar.Add("Trip started!");
            await LoadData();
        }
        else
        {
            Snackbar.Add(await response.Content.ReadAsStringAsync());
        }
    }

    private async Task CompleteTrip()
    {
        var response = await Http.PutAsJsonAsync($"/api/v1/trips/{Id}/complete", new { });
        if (response.IsSuccessStatusCode)
        {
            Snackbar.Add("Trip completed!");
            await LoadData();
        }
        else
        {
            Snackbar.Add(await response.Content.ReadAsStringAsync());
        }
    }

    private void OpenLogDialog()
    {
        _logForm         = new LogForm();
        _hoverCount      = 0;
        _isDragging       = false;
        _showCustomInput  = false;
        _logDialogVisible = true;
    }

    private async Task SaveLog()
    {
        var payload = new NextStopRequest
        {
            TripId         = Id,
            PassengerCount = _logForm.PassengerCount
        };
        var response = await Http.PostAsJsonAsync($"/api/v1/trips/{Id}/next", payload);
        if (response.IsSuccessStatusCode)
        {
            Snackbar.Add("Trip log added!");
            await LoadData();
        }
        else
        {
            Snackbar.Add(await response.Content.ReadAsStringAsync());
        }
        _logDialogVisible = false;
    }

    // ── Inner types ───────────────────────────────────────────────────

    public class LogForm
    {
        public int    StopId         { get; set; }
        public int    PassengerCount { get; set; }
        public string EventType      { get; set; } = string.Empty;
    }

    public class StopOption
    {
        public int    Id   { get; set; }
        public string Name { get; set; } = string.Empty;
    }
}
