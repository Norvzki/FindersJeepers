@using MudBlazor

<MudDialog Visible="Visible" Options="_options" OnBackdropClick="OnCancel">
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.PlayArrow" Color="Color.Success" />
            <MudText Typo="Typo.h6" Class="fw-bold">Start New Trip</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        @if (Jeeps is null)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-2" />
        }
        else if (!Jeeps.Any())
        {
            <MudAlert Severity="Severity.Warning">No jeepneys assigned to this driver.</MudAlert>
        }
        else
        {
            <MudText Typo="Typo.subtitle2" Class="mud-text-secondary mb-2">Select a Jeepney</MudText>
            <MudStack Spacing="2" Class="mb-4">
                @foreach (var jeep in Jeeps)
                {
                    bool sel = SelectedJeepId == jeep.Id;
                    <MudPaper Outlined="true"
                              Style="@($"border-radius:8px; cursor:pointer; border-color:{(sel ? "var(--mud-palette-success)" : "var(--mud-palette-lines-default)")}")"
                              Class="@($"pa-3 {(sel ? "mud-success-hover" : "")}")"
                              @onclick="() => SelectedJeepIdChanged.InvokeAsync(jeep.Id)">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                            <MudAvatar Color="Color.Secondary" Variant="Variant.Filled" Size="Size.Medium">
                                <MudIcon Icon="@Icons.Material.Filled.DirectionsBus" />
                            </MudAvatar>
                            <MudStack Spacing="0" Style="flex:1;">
                                <MudText Typo="Typo.body1" Class="fw-bold">@jeep.PlateNumber</MudText>
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                    Body #@jeep.BodyNumber · Route: @jeep.RouteCode · Cap: @jeep.Capacity
                                </MudText>
                            </MudStack>
                        </MudStack>
                    </MudPaper>
                }
            </MudStack>

            <MudDivider Class="mb-3" />
            <MudText Typo="Typo.subtitle2" Class="mud-text-secondary mb-2">Select Direction</MudText>
            <MudStack Row="true" Spacing="2">
                @foreach (var (dir, icon, label) in _directions)
                {
                    bool active = Direction == dir;
                    <MudPaper Outlined="true"
                              Style="@($"border-radius:8px; cursor:pointer; flex:1; border-color:{(active ? "var(--mud-palette-primary)" : "var(--mud-palette-lines-default)")}")"
                              Class="@($"pa-3 {(active ? "mud-primary-hover" : "")}")"
                              @onclick="() => DirectionChanged.InvokeAsync(dir)">
                        <MudStack AlignItems="AlignItems.Center" Spacing="1">
                            <MudIcon Icon="@icon" Color="@(active? Color.Primary: Color.Default)" />
                            <MudText Typo="Typo.body2" Class="fw-bold">@label</MudText>
                        </MudStack>
                    </MudPaper>
                }
            </MudStack>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="OnCancel">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Success"
                   StartIcon="@Icons.Material.Filled.PlayArrow"
                   Disabled="@(SelectedJeepId is null)"
                   OnClick="OnConfirm">
            Start Trip
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public bool Visible { get; set; }
    [Parameter] public List<JeepneySummary>? Jeeps { get; set; }
    [Parameter] public int? SelectedJeepId { get; set; }
    [Parameter] public EventCallback<int?> SelectedJeepIdChanged { get; set; }
    [Parameter] public RouteDirection Direction { get; set; } = RouteDirection.Forward;
    [Parameter] public EventCallback<RouteDirection> DirectionChanged { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }
    [Parameter] public EventCallback OnConfirm { get; set; }

    private readonly DialogOptions _options = new()
    { MaxWidth = MaxWidth.Small, FullWidth = true, CloseOnEscapeKey = true };

    private readonly (RouteDirection Dir, string Icon, string Label)[] _directions =
    {
        (RouteDirection.Forward, Icons.Material.Filled.ArrowForward, "Forward"),
        (RouteDirection.Return,  Icons.Material.Filled.ArrowBack,    "Returning")
    };
}