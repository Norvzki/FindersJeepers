@using MudBlazor

<MudDialog Visible="Visible" Options="_options">
    <TitleContent>
        <MudText Typo="Typo.h6" Class="fw-bold">Assign Jeepneys</MudText>
    </TitleContent>
    <DialogContent>
        @if (AvailableJeepneys is null)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
        }
        else if (!AvailableJeepneys.Any())
        {
            <MudAlert Severity="Severity.Info" Dense="true">No jeepneys available to assign.</MudAlert>
        }
        else
        {
            <MudText Typo="Typo.body2" Class="mud-text-secondary mb-3">
                Select one or more jeepneys to assign to this driver.
            </MudText>
            <MudStack Spacing="2">
                @foreach (var j in AvailableJeepneys)
                {
                    bool sel = SelectedJeepneyIds.Contains(j.Id);
                    <MudPaper Outlined="true"
                              Style="@($"border-radius:8px; cursor:pointer; border-color:{(sel ? "var(--mud-palette-primary)" : "var(--mud-palette-lines-default)")}")"
                              Class="@($"pa-3 {(sel ? "mud-primary-hover" : "")}")"
                              @onclick="() => OnToggleJeepney.InvokeAsync(j.Id)">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                            <MudCheckBox Value="sel" Color="Color.Primary" ReadOnly="true" />
                            <MudAvatar Color="Color.Secondary" Variant="Variant.Filled" Size="Size.Medium">
                                <MudIcon Icon="@Icons.Material.Filled.DirectionsBus" />
                            </MudAvatar>
                            <MudStack Spacing="0" Style="flex:1;">
                                <MudText Typo="Typo.body1" Class="fw-bold">@j.PlateNumber</MudText>
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                    Body #@j.BodyNumber · Route: @j.RouteCode · Capacity: @j.Capacity
                                </MudText>
                            </MudStack>
                            <MudChip T="string" Size="Size.Small"
                                     Color="@(j.NumberOfDrivers == 0 ? Color.Warning : Color.Default)"
                                     Variant="Variant.Outlined">
                                @j.NumberOfDrivers driver(s)
                            </MudChip>
                        </MudStack>
                    </MudPaper>
                }
            </MudStack>
        }
    </DialogContent>
    <DialogActions>
        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="w-100 px-2">
            <MudText Typo="Typo.caption" Class="mud-text-secondary">
                @SelectedJeepneyIds.Count jeepney(s) selected
            </MudText>
            <MudStack Row="true" Spacing="2">
                <MudButton OnClick="OnCancel">Cancel</MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           Disabled="@(!SelectedJeepneyIds.Any())"
                           OnClick="OnConfirm">
                    Assign
                </MudButton>
            </MudStack>
        </MudStack>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public bool Visible { get; set; }
    [Parameter] public List<JeepneyOption>? AvailableJeepneys { get; set; }
    [Parameter, EditorRequired] public HashSet<int> SelectedJeepneyIds { get; set; } = new();
    [Parameter] public EventCallback<int> OnToggleJeepney { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }
    [Parameter] public EventCallback OnConfirm { get; set; }

    private readonly DialogOptions _options = new()
    { MaxWidth = MaxWidth.Small, FullWidth = true, CloseOnEscapeKey = true };
}