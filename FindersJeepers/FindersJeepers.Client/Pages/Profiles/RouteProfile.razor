@page "/routes/{Id:int}"
@using MudBlazor
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject NavigationManager Nav

<style>
    .timeline-wrapper {
        transition: opacity 0.25s ease, transform 0.25s ease;
    }

        .timeline-wrapper.fading {
            opacity: 0;
            transform: translateX(10px);
        }
</style>

@if (_route is null)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    var accent = _showReturn ? Color.Warning : Color.Primary;
    var accentCss = _showReturn ? "var(--mud-palette-warning)" : "var(--mud-palette-primary)";
    var originLabel = _showReturn ? _route.LocationEnd : _route.LocationStart;
    var destLabel = _showReturn ? _route.LocationStart : _route.LocationEnd;
    var activeStops = _showReturn ? _route.ReturnStops : _route.Stops;

    <MudBreadcrumbs Items="_breadcrumbs" Class="mb-4 px-0" />

    <MudGrid Spacing="4">

        <MudItem xs="12" md="4">
            <MudStack Spacing="4">

                <MudCard Elevation="2" Style="border-radius:14px;">
                    <MudCardContent Class="d-flex flex-column align-items-center text-center pa-6">

                        <MudAvatar Color="@accent"
                                   Style="width:80px;height:80px; transition:background-color 0.35s ease;"
                                   Class="mb-3"
                                   Variant="Variant.Filled">
                            <MudIcon Icon="@Icons.Material.Filled.AltRoute" Style="font-size:2.2rem;" />
                        </MudAvatar>

                        <MudText Typo="Typo.h5" Class="fw-bold mb-1">@_route.RouteCode</MudText>

                        <MudText Typo="Typo.body2" Class="mud-text-secondary mb-3">
                            @originLabel.Name → @destLabel.Name
                        </MudText>

                        <MudDivider Class="w-100 my-4" />

                        <MudStack Row="true" Justify="Justify.SpaceEvenly" Class="w-100">
                            <MudStack Spacing="0" AlignItems="AlignItems.Center">
                                <MudText Typo="Typo.h6" Class="fw-bold">@_route.Stops.Count</MudText>
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">Fwd Stops</MudText>
                            </MudStack>
                            <MudDivider Vertical="true" FlexItem="true" />
                            <MudStack Spacing="0" AlignItems="AlignItems.Center">
                                <MudText Typo="Typo.h6" Class="fw-bold">@_route.ReturnStops.Count</MudText>
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">Ret Stops</MudText>
                            </MudStack>
                            <MudDivider Vertical="true" FlexItem="true" />
                            <MudStack Spacing="0" AlignItems="AlignItems.Center">
                                <MudText Typo="Typo.h6" Class="fw-bold">@_route.AssignedJeepneys.Count</MudText>
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">Jeepneys</MudText>
                            </MudStack>
                        </MudStack>

                        <MudDivider Class="w-100 my-4" />

                        @* ── Edit / Delete ── *@
                        <MudButtonGroup Variant="Variant.Outlined" Class="w-100">
                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       FullWidth="true"
                                       StartIcon="@Icons.Material.Filled.Edit"
                                       OnClick="OpenEditDialog">
                                Edit
                            </MudButton>
                            <MudMenu Icon="@Icons.Material.Filled.ArrowDropDown">
                                <MudMenuItem OnClick="OpenDeleteConfirmation"
                                             Icon="@Icons.Material.Filled.DeleteOutline"
                                             IconColor="Color.Error">
                                    Delete Route
                                </MudMenuItem>
                            </MudMenu>
                        </MudButtonGroup>

                    </MudCardContent>
                </MudCard>

                @* Assigned Jeepneys *@
                <MudCard Elevation="2" Style="border-radius:14px;">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6" Class="fw-bold">Assigned Jeepneys</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudDivider />
                    <MudCardContent Class="pa-0">
                        @if (!_route.AssignedJeepneys.Any())
                        {
                            <MudAlert Severity="Severity.Info" Dense="true" Class="ma-3">
                                No jeepneys on this route.
                            </MudAlert>
                        }
                        else
                        {
                            <MudList T="JeepneySummary" Dense="true" DisablePadding="true">
                                @foreach (var j in _route.AssignedJeepneys)
                                {
                                    <MudListItem T="JeepneySummary" Class="px-4 py-2">
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                                <MudAvatar Color="Color.Secondary" Size="Size.Small" Variant="Variant.Filled">
                                                    <MudIcon Icon="@Icons.Material.Filled.DirectionsBus" Size="Size.Small" />
                                                </MudAvatar>
                                                <MudStack Spacing="0">
                                                    <MudText Typo="Typo.body2" Class="fw-bold">@j.PlateNumber</MudText>
                                                </MudStack>
                                            </MudStack>
                                            <MudIconButton Icon="@Icons.Material.Filled.OpenInNew"
                                                           Size="Size.Small"
                                                           Href="@($"/jeepneys/{j.Id}")" />
                                        </MudStack>
                                    </MudListItem>
                                    <MudDivider />
                                }
                            </MudList>
                        }
                    </MudCardContent>
                </MudCard>

            </MudStack>
        </MudItem>

        @* ── Right column: stop sequence ── *@
        <MudItem xs="12" md="8">
            <MudCard Elevation="2" Style="border-radius:14px;">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6" Class="fw-bold">Stop Sequence</MudText>
                        <MudText Typo="Typo.body2" Class="mud-text-secondary">
                            Visual timeline of stops along this route.
                        </MudText>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <MudStack AlignItems="AlignItems.End" Spacing="2">
                            <MudButton Variant="Variant.Outlined"
                                       Color="@accent"
                                       Size="Size.Small"
                                       StartIcon="@Icons.Material.Filled.Edit"
                                       Style="transition:color 0.3s ease, border-color 0.3s ease;"
                                       OnClick="OpenManageStopsDialog">
                                Manage Stops
                            </MudButton>
                            <MudStack Row="true" Spacing="1">
                                <MudButton Variant="Variant.Outlined"
                                           Color="@accent"
                                           Size="Size.Small"
                                           StartIcon="@(_showReturn ? Icons.Material.Filled.ArrowBack : Icons.Material.Filled.ArrowForward)"
                                           EndIcon="@Icons.Material.Filled.SyncAlt"
                                           Style="transition:color 0.3s ease; text-transform:none;"
                                           OnClick="async () => await SetDirection(!_showReturn)">
                                    @(_showReturn ? "Return" : "Forward")
                                </MudButton>
                                @if (!_showReturn && _route.Stops.Any() && !_route.ReturnStops.Any())
                                {
                                    <MudTooltip Text="Auto-generate return stops by reversing forward stops">
                                        <MudButton Variant="Variant.Outlined"
                                                   Color="Color.Warning"
                                                   Size="Size.Small"
                                                   StartIcon="@Icons.Material.Filled.AutoFixHigh"
                                                   Style="text-transform:none;"
                                                   OnClick="GenerateReturnStops">
                                            Gen Return
                                        </MudButton>
                                    </MudTooltip>
                                }
                            </MudStack>
                        </MudStack>
                    </CardHeaderActions>
                </MudCardHeader>
                <MudDivider />
                <MudCardContent>

                    <div class="@($"timeline-wrapper{(_isFading ? " fading" : "")}")">

                        @if (!activeStops.Any())
                        {
                            <MudAlert Severity="Severity.Info" Dense="true">
                                No stops defined yet. Use "Manage Stops" to build the route sequence.
                            </MudAlert>
                        }
                        else
                        {
                            <MudTimeline TimelinePosition="TimelinePosition.Start" Class="mt-2">

                                @* Origin *@
                                <MudTimelineItem Color="@accent" Size="Size.Medium" Variant="Variant.Filled">
                                    <ItemDot>
                                        <MudIcon Icon="@Icons.Material.Filled.TripOrigin" Size="Size.Small" />
                                    </ItemDot>
                                    <ItemContent>
                                        <MudStack Spacing="0">
                                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                                <MudText Typo="Typo.body1" Class="fw-bold">@originLabel.Name</MudText>
                                                <MudChip T="string" Size="Size.Small" Color="@accent" Variant="Variant.Outlined">Origin</MudChip>
                                            </MudStack>
                                            <MudText Typo="Typo.caption" Class="mud-text-secondary">Start of route</MudText>
                                        </MudStack>
                                    </ItemContent>
                                </MudTimelineItem>

                                @* Middle stops *@
                                @foreach (var stop in activeStops.OrderBy(s => s.StopIndex))
                                {
                                    <MudTimelineItem Color="Color.Default" Size="Size.Small" Variant="Variant.Outlined">
                                        <ItemDot>
                                            <MudIcon Icon="@Icons.Material.Filled.FiberManualRecord" Size="Size.Small" />
                                        </ItemDot>
                                        <ItemContent>
                                            <MudStack Spacing="0">
                                                <MudText Typo="Typo.body1" Class="fw-bold">@stop.LocationName</MudText>
                                                <MudText Typo="Typo.caption" Class="mud-text-secondary">Stop #@stop.StopIndex</MudText>
                                            </MudStack>
                                        </ItemContent>
                                    </MudTimelineItem>
                                }

                                @* Destination *@
                                <MudTimelineItem Color="@accent" Size="Size.Medium" Variant="Variant.Filled">
                                    <ItemDot>
                                        <MudIcon Icon="@Icons.Material.Filled.Place" Size="Size.Small" />
                                    </ItemDot>
                                    <ItemContent>
                                        <MudStack Spacing="0">
                                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                                <MudText Typo="Typo.body1" Class="fw-bold">@destLabel.Name</MudText>
                                                <MudChip T="string" Size="Size.Small" Color="@accent" Variant="Variant.Outlined">Destination</MudChip>
                                            </MudStack>
                                            <MudText Typo="Typo.caption" Class="mud-text-secondary">End of route</MudText>
                                        </MudStack>
                                    </ItemContent>
                                </MudTimelineItem>

                            </MudTimeline>
                        }
                    </div>

                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>

    @* ── Edit Route Dialog ── *@
    <MudDialog Visible="_editDialogVisible" Options="_smallDialogOptions">
        <TitleContent>
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" />
                <MudText Typo="Typo.h6" Class="fw-bold">Edit Route</MudText>
            </MudStack>
        </TitleContent>
        <DialogContent>
            <MudStack Spacing="3" Class="pt-1">
                <MudTextField @bind-Value="_editForm.RouteCode"
                              Label="Route Code"
                              Variant="Variant.Outlined"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Tag"
                              Required="true" />

                <MudSelect T="int"
                           @bind-Value="_editForm.LocationStartId"
                           Label="Start Location"
                           Variant="Variant.Outlined"
                           Adornment="Adornment.Start"
                           AdornmentIcon="@Icons.Material.Filled.TripOrigin"
                           AdornmentColor="Color.Primary">
                    @foreach (var loc in _allLocations)
                    {
                        <MudSelectItem Value="@loc.Id">@loc.Name</MudSelectItem>
                    }
                </MudSelect>

                <MudSelect T="int"
                           @bind-Value="_editForm.LocationEndId"
                           Label="End Location"
                           Variant="Variant.Outlined"
                           Adornment="Adornment.Start"
                           AdornmentIcon="@Icons.Material.Filled.Place"
                           AdornmentColor="Color.Error">
                    @foreach (var loc in _allLocations)
                    {
                        <MudSelectItem Value="@loc.Id">@loc.Name</MudSelectItem>
                    }
                </MudSelect>

                @if (_editForm.LocationStartId != 0 && _editForm.LocationStartId == _editForm.LocationEndId)
                {
                    <MudAlert Severity="Severity.Warning" Dense="true">
                        Start and end location cannot be the same.
                    </MudAlert>
                }
            </MudStack>
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="() => _editDialogVisible = false">Cancel</MudButton>
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       Disabled="@(_editForm.LocationStartId == _editForm.LocationEndId || string.IsNullOrWhiteSpace(_editForm.RouteCode))"
                       OnClick="SaveEdit">
                Save Changes
            </MudButton>
        </DialogActions>
    </MudDialog>

    @* ── Delete Confirmation Dialog ── *@
    <MudDialog Visible="_deleteDialogVisible" Options="_smallDialogOptions">
        <TitleContent>
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@Icons.Material.Filled.DeleteForever" Color="Color.Error" />
                <MudText Typo="Typo.h6" Class="fw-bold">Delete Route</MudText>
            </MudStack>
        </TitleContent>
        <DialogContent>
            <MudText Typo="Typo.body1">
                Are you sure you want to delete <b>@_route.RouteCode</b>? This action cannot be undone.
            </MudText>
            @if (_route.AssignedJeepneys.Any())
            {
                <MudAlert Severity="Severity.Warning" Dense="true" Class="mt-3">
                    This route has @_route.AssignedJeepneys.Count assigned jeepney(s). Make sure to reassign them first.
                </MudAlert>
            }
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="() => _deleteDialogVisible = false">Cancel</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="ConfirmDelete">
                Delete
            </MudButton>
        </DialogActions>
    </MudDialog>

    @* ── Manage Stops Dialog ── *@
    <MudDialog Visible="_dialogVisible" Options="_dialogOptions">
        <TitleContent>
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@Icons.Material.Filled.Route" Color="@accent" />
                <MudText Typo="Typo.h6" Class="fw-bold">
                    Build @(_showReturn ? "Return" : "Forward") Route Sequence
                </MudText>
                <MudChip T="string" Size="Size.Small" Color="@accent" Variant="Variant.Outlined">
                    @originLabel → @destLabel
                </MudChip>
            </MudStack>
        </TitleContent>
        <DialogContent>
            <MudGrid Style="min-height:400px;">

                @* ── Left: search & add ── *@
                <MudItem xs="12" md="5">
                    <MudText Typo="Typo.caption" Class="mud-text-secondary mb-2 d-block">
                        SEARCH & ADD STOPS
                    </MudText>
                    <MudTextField T="string"
                                  Label="Search locations..."
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Adornment="Adornment.End"
                                  AdornmentIcon="@Icons.Material.Filled.Search"
                                  @bind-Value="_searchQuery"
                                  Immediate="true"
                                  Clearable="true" />

                    <MudDivider Class="my-3" />

                    @{
                        var filtered = string.IsNullOrWhiteSpace(_searchQuery)
                            ? _allLocations
                            : _allLocations
                                .Where(l => l.Name.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase))
                                .ToList();
                    }

                    @if (!filtered.Any())
                    {
                        <MudText Typo="Typo.body2" Class="mud-text-secondary text-center mt-4">
                            No locations found.
                        </MudText>
                    }
                    else
                    {
                        <MudList T="LocationDto" DisablePadding="true" Style="max-height:340px; overflow-y:auto;">
                            @foreach (var loc in filtered)
                            {
                                bool alreadyAdded = _stops.Any(s => s.Id == loc.Id);
                                <MudListItem T="LocationDto"
                                             Disabled="@alreadyAdded"
                                             OnClick="() => AddStop(loc)"
                                             Class="rounded mb-1">
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                        <MudStack Spacing="0">
                                            <MudText Typo="Typo.body2" Class="fw-bold">@loc.Name</MudText>
                                            <MudText Typo="Typo.caption" Class="mud-text-secondary">@loc.Description</MudText>
                                        </MudStack>
                                        <MudIcon Icon="@(alreadyAdded ? Icons.Material.Filled.Check : Icons.Material.Filled.AddCircleOutline)"
                                                 Size="Size.Small"
                                                 Color="@(alreadyAdded ? Color.Success : accent)" />
                                    </MudStack>
                                </MudListItem>
                            }
                        </MudList>
                    }
                </MudItem>

                @* ── Divider ── *@
                <MudItem xs="12" md="1" Class="d-flex justify-center">
                    <MudDivider Vertical="true" FlexItem="true" />
                </MudItem>

                @* ── Route builder ── *@
                <MudItem xs="12" md="6">
                    <MudText Typo="Typo.caption" Class="mud-text-secondary mb-2 d-block">
                        ROUTE SEQUENCE
                    </MudText>
                    <MudText Typo="Typo.caption" Class="mud-text-secondary mb-3 d-block">
                        Stops between <b>@originLabel</b> and <b>@destLabel</b>
                    </MudText>

                    <MudTimeline TimelinePosition="TimelinePosition.Start">

                        @* Fixed origin *@
                        <MudTimelineItem Color="@accent" Size="Size.Small" Variant="Variant.Filled">
                            <ItemContent>
                                <MudPaper Outlined="true" Class="pa-3" Style="@($"border-radius:8px; border-color:{accentCss};")">
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                        <MudIcon Icon="@Icons.Material.Filled.TripOrigin" Size="Size.Small" Color="@accent" />
                                        <MudStack Spacing="0" Style="flex:1;">
                                            <MudText Typo="Typo.body2" Class="fw-bold">@originLabel</MudText>
                                            <MudText Typo="Typo.caption" Class="mud-text-secondary">Origin · cannot be changed</MudText>
                                        </MudStack>
                                    </MudStack>
                                </MudPaper>
                            </ItemContent>
                        </MudTimelineItem>

                        @* Dynamic stops *@
                        @if (!_stops.Any())
                        {
                            <MudTimelineItem Color="Color.Default" Size="Size.Small" Variant="Variant.Outlined">
                                <ItemContent>
                                    <MudPaper Outlined="true" Class="pa-3" Style="border-radius:8px; border-style:dashed;">
                                        <MudText Typo="Typo.body2" Class="mud-text-secondary text-center fst-italic">
                                            Search and add stops on the left.
                                        </MudText>
                                    </MudPaper>
                                </ItemContent>
                            </MudTimelineItem>
                        }
                        else
                        {
                            @for (int i = 0; i < _stops.Count; i++)
                            {
                                var index = i;
                                var stop = _stops[i];
                                <MudTimelineItem Color="Color.Default" Size="Size.Small" Variant="Variant.Outlined">
                                    <ItemContent>
                                        <MudPaper Elevation="1" Class="pa-2" Style="border-radius:8px;">
                                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                                <MudStack Spacing="0" Style="flex:1;">
                                                    <MudText Typo="Typo.body2" Class="fw-bold">@stop.Name</MudText>
                                                    <MudText Typo="Typo.caption" Class="mud-text-secondary">Stop #@(index + 1)</MudText>
                                                </MudStack>
                                                <MudStack Row="true" Spacing="0">
                                                    <MudIconButton Icon="@Icons.Material.Filled.KeyboardArrowUp"
                                                                   Size="Size.Small"
                                                                   Disabled="@(index == 0)"
                                                                   OnClick="() => MoveStop(index, -1)" />
                                                    <MudIconButton Icon="@Icons.Material.Filled.KeyboardArrowDown"
                                                                   Size="Size.Small"
                                                                   Disabled="@(index == _stops.Count - 1)"
                                                                   OnClick="() => MoveStop(index, 1)" />
                                                    <MudIconButton Icon="@Icons.Material.Filled.DeleteOutline"
                                                                   Size="Size.Small"
                                                                   Color="Color.Error"
                                                                   OnClick="() => RemoveStop(index)" />
                                                </MudStack>
                                            </MudStack>
                                        </MudPaper>
                                    </ItemContent>
                                </MudTimelineItem>
                            }
                        }

                        @* Fixed destination *@
                        <MudTimelineItem Color="@accent" Size="Size.Small" Variant="Variant.Filled">
                            <ItemContent>
                                <MudPaper Outlined="true" Class="pa-3" Style="@($"border-radius:8px; border-color:{accentCss};")">
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                        <MudIcon Icon="@Icons.Material.Filled.Place" Size="Size.Small" Color="@accent" />
                                        <MudStack Spacing="0" Style="flex:1;">
                                            <MudText Typo="Typo.body2" Class="fw-bold">@destLabel</MudText>
                                            <MudText Typo="Typo.caption" Class="mud-text-secondary">Destination · cannot be changed</MudText>
                                        </MudStack>
                                    </MudStack>
                                </MudPaper>
                            </ItemContent>
                        </MudTimelineItem>

                    </MudTimeline>
                </MudItem>

            </MudGrid>
        </DialogContent>
        <DialogActions>
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="w-100 px-2">
                <MudText Typo="Typo.caption" Class="mud-text-secondary">
                    @_stops.Count intermediate stop(s)
                </MudText>
                <MudStack Row="true" Spacing="2">
                    <MudButton OnClick="() => _dialogVisible = false">Cancel</MudButton>
                    <MudButton Color="@accent" Variant="Variant.Filled" OnClick="SaveStops">
                        Save Sequence
                    </MudButton>
                </MudStack>
            </MudStack>
        </DialogActions>
    </MudDialog>
}

@code {
    [Parameter] public int Id { get; set; }

    private RouteDetail? _route;
    private List<BreadcrumbItem> _breadcrumbs = new();

    // ── All locations (loaded once) ──
    private List<LocationDto> _allLocations = new();

    // ── Direction toggle ──
    private bool _showReturn = false;
    private bool _isFading = false;

    private async Task SetDirection(bool returnDirection)
    {
        if (_showReturn == returnDirection) return;
        _isFading = true;
        StateHasChanged();
        await Task.Delay(220);
        _showReturn = returnDirection;
        _isFading = false;
        StateHasChanged();
    }

    // ── Dialog options ──
    private DialogOptions _dialogOptions = new()
    {
        MaxWidth = MaxWidth.Large,
        FullWidth = true,
        CloseOnEscapeKey = true
    };

    private DialogOptions _smallDialogOptions = new()
    {
        MaxWidth = MaxWidth.Small,
        FullWidth = true,
        CloseOnEscapeKey = true
    };

    // ── Manage Stops dialog state ──
    private bool _dialogVisible = false;
    private string _searchQuery = string.Empty;
    private List<LocationDto> _stops = new();

    // ── Edit dialog state ──
    private bool _editDialogVisible = false;
    private UpdateRouteRequest _editForm = new();

    // ── Delete dialog state ──
    private bool _deleteDialogVisible = false;

    // ── Init ──
    protected override async Task OnInitializedAsync()
    {
        await LoadRoute();
        _allLocations = await Http.GetFromJsonAsync<List<LocationDto>>("/api/v1/locations") ?? new();
    }

    private async Task LoadRoute()
    {
        _route = await Http.GetFromJsonAsync<RouteDetail>($"/api/v1/routes/{Id}");
        _breadcrumbs = new List<BreadcrumbItem>
        {
            new("Routes", href: "/routes"),
            new(_route!.RouteCode, href: null, disabled: true)
        };
    }

    // ── Edit ──
    private void OpenEditDialog()
    {
        _editForm = new UpdateRouteRequest
        {
            Id = _route!.Id,
            RouteCode = _route.RouteCode,
            LocationStartId = _route.LocationStart.Id,
            LocationEndId = _route.LocationEnd.Id,
        };
        _editDialogVisible = true;
    }

    private async Task SaveEdit()
    {
        var response = await Http.PutAsJsonAsync($"/api/v1/routes/{Id}", _editForm);
        if (response.IsSuccessStatusCode)
        {
            Snackbar.Add("Route updated.", Severity.Success);
            _editDialogVisible = false;
            await LoadRoute();
        }
        else
        {
            Snackbar.Add(await response.Content.ReadAsStringAsync(), Severity.Error);
        }
    }

    // ── Delete ──
    private void OpenDeleteConfirmation() => _deleteDialogVisible = true;

    private async Task ConfirmDelete()
    {
        var response = await Http.DeleteAsync($"/api/v1/routes/{Id}");
        if (response.IsSuccessStatusCode)
        {
            Snackbar.Add("Route deleted.", Severity.Success);
            Nav.NavigateTo("/routes");
        }
        else
        {
            Snackbar.Add(await response.Content.ReadAsStringAsync(), Severity.Error);
            _deleteDialogVisible = false;
        }
    }

    // ── Generate Return Stops ──
    private async Task GenerateReturnStops()
    {
        var response = await Http.PostAsync($"/api/v1/routes/{Id}/generate-return-stops", null);
        if (response.IsSuccessStatusCode)
        {
            Snackbar.Add("Return stops generated from forward stops.", Severity.Success);
            await LoadRoute();
            await SetDirection(true);
        }
        else
        {
            Snackbar.Add(await response.Content.ReadAsStringAsync(), Severity.Error);
        }
    }

    // ── Manage Stops ──
    private void OpenManageStopsDialog()
    {
        var source = _showReturn ? _route!.ReturnStops : _route!.Stops;
        _stops = source
            .OrderBy(s => s.StopIndex)
            .Select(s => new LocationDto { Id = s.LocationId, Name = s.LocationName })
            .ToList();

        _searchQuery = string.Empty;
        _dialogVisible = true;
    }

    private void AddStop(LocationDto loc)
    {
        if (_stops.Any(s => s.Id == loc.Id)) return;
        _stops.Add(loc);
    }

    private void RemoveStop(int index) => _stops.RemoveAt(index);

    private void MoveStop(int index, int direction)
    {
        var item = _stops[index];
        _stops.RemoveAt(index);
        _stops.Insert(index + direction, item);
    }

    private async Task SaveStops()
    {
        var stops = _stops.Select((s, i) => new LocationIndexPair { LocationId = s.Id, Index = i + 1 }).ToList();
        var request = new AddRouteStopRequest
        {
            RouteId = Id,
            RouteStops = stops,
            RouteDirection = _showReturn ? RouteDirection.Return : RouteDirection.Forward
        };
        var response = await Http.PutAsJsonAsync($"/api/v1/routes/{Id}/stops", request);

        if (response.IsSuccessStatusCode)
        {
            Snackbar.Add("Route sequence saved.", Severity.Success);
            _dialogVisible = false;
            await LoadRoute();
        }
        else
        {
            Snackbar.Add(await response.Content.ReadAsStringAsync(), Severity.Error);
        }
    }
}